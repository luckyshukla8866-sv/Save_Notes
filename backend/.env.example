# === Application ===
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
DEBUG=true

# === MongoDB ===
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=notevault

# === Security ===
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_CREATE=3/minute
RATE_LIMIT_READ=10/minute
MAX_NOTE_SIZE=51200
MAX_EXPIRY_HOURS=168
MIN_CODE_LENGTH=8
MAX_CODE_LENGTH=32
